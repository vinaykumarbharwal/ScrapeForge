datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String         @unique
  passwordHash   String?        @map("password_hash")
  oauthProvider  String?        @map("oauth_provider")
  oauthId        String?        @map("oauth_id")
  plan           String         @default("free")
  apiKeyHash     String?        @map("api_key_hash")
  timezone       String         @default("UTC")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  scrapeTasks    ScrapeTask[]
  templates      Template[]
  notifications  Notification[]

  @@map("users")
}

model ScrapeTask {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  config         Json
  scheduleCron   String?          @map("schedule_cron")
  status         String           @default("active")
  lastRunAt      DateTime?        @map("last_run_at") @db.Timestamptz
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz
  taskRuns       TaskRun[]
  schemaRegistry SchemaRegistry[]

  @@map("scrape_tasks")
}

model TaskRun {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId       String      @map("task_id") @db.Uuid
  task         ScrapeTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  startedAt    DateTime    @default(now()) @map("started_at") @db.Timestamptz
  finishedAt   DateTime?   @map("finished_at") @db.Timestamptz
  status       String      @default("running")
  rowsScraped  Int         @default(0) @map("rows_scraped")
  pagesVisited Int         @default(0) @map("pages_visited")
  errorLog     String?     @map("error_log")
  durationMs   Int?        @map("duration_ms")
  exports      Export[]

  @@map("task_runs")
}

model Template {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  user           User?    @relation(fields: [userId], references: [id])
  name           String
  description    String?
  selectorConfig Json     @map("selector_config")
  isPublic       Boolean  @default(false) @map("is_public")
  useCount       Int      @default(0) @map("use_count")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("templates")
}

model Export {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskRunId     String   @map("task_run_id") @db.Uuid
  taskRun       TaskRun  @relation(fields: [taskRunId], references: [id], onDelete: Cascade)
  format        String
  fileUrl       String?  @map("file_url")
  fileSizeBytes BigInt?  @map("file_size_bytes")
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("exports")
}

model SchemaRegistry {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId    String     @map("task_id") @db.Uuid
  task      ScrapeTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  version   Int
  columns   Json
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz

  @@unique([taskId, version])
  @@map("schema_registry")
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType String   @map("event_type")
  channel   String
  config    Json
  isActive  Boolean  @default(true) @map("is_active")

  @@map("notifications")
}
